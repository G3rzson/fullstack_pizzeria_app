generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  email              String   @unique
  password           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  role               Role     @default(USER)
  isStillWorkingHere Boolean  @default(false)

  orderAddress OrderAddress?
}

model OrderAddress {
  id           String   @id @default(uuid())
  fullName     String
  phoneNumber  String
  street       String
  city         String
  postalCode   String
  houseNumber  String
  floorAndDoor String?
  isSaved      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Pizza {
  id                String   @id @default(uuid())
  pizzaName         String
  pizzaDescription  String
  pizzaPrice32      Float
  pizzaPrice45      Float
  isAvailableOnMenu Boolean
  createdBy         String
  category          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  image             Image?
}

model Pasta {
  id                String   @id @default(uuid())
  pastaName         String
  pastaDescription  String
  pastaPrice        Float
  isAvailableOnMenu Boolean
  createdBy         String
  category          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  image             Image?
}

model Drink {
  id                String   @id @default(uuid())
  drinkName         String
  drinkPrice        Float
  isAvailableOnMenu Boolean
  createdBy         String
  category          String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  image             Image?
}

model Image {
  id           String @id @default(uuid())
  publicId     String
  publicUrl    String
  originalName String

  pizzaId String? @unique
  pastaId String? @unique
  drinkId String? @unique

  pizza Pizza? @relation(fields: [pizzaId], references: [id], onDelete: Cascade)
  pasta Pasta? @relation(fields: [pastaId], references: [id], onDelete: Cascade)
  drink Drink? @relation(fields: [drinkId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
