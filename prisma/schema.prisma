generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Pizza {
  id                String   @id @default(uuid())
  pizzaName         String
  pizzaDescription  String
  pizzaPrice32      Float
  pizzaPrice45      Float
  isAvailableOnMenu Boolean
  publicId          String?
  originalName      String?
  publicUrl         String?
  createdBy         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
